# Secrets — never bake into the image
.env
.env.*

# Python runtime artifacts
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/

# Virtual environments
venv/
.venv/
env/

# Node (re-installed inside Docker)
node_modules/

# Django runtime output — generated by entrypoint
staticfiles/
media/
db.sqlite3

# Built CSS — rebuilt inside Docker from source
static/dist/

# Version control
.git/
.gitignore

# Docs / local config
README.md
*.log
.DS_Store
.idea/
.vscode/

# Docker files themselves
Dockerfile
docker-compose.yml
.dockerignore
